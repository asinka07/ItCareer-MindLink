@using MindLink.Data.Services
@inject NavigationManager NavManager
@inject UserSessionService Session
<link href="/css/site.css" rel="stylesheet" />
<link href="/css/custom-navbar.css" rel="stylesheet" />

<div class="top-row ps-3 navbar navbar-dark" style="gap: 10px; flex-direction: row!important; flex-wrap: nowrap!important; justify-content: space-between!important; padding-right: 12px!important;">
    <div style="display: flex; align-items: center; gap: 10px;">
        @if (Session.IsLoggedIn && Session.CurrentUser?.RoleId == 1)
        {
            <a href="\homepage"><img src="\images\logo-1.svg" alt="" style="height: 30px;"></a>
            <a class="navbar-brand" href="\homepage" style="font-family: serif!important;">MindLink</a>
        }
        @if (Session.IsLoggedIn && Session.CurrentUser?.RoleId == 2)
        {
            <a href="\admin\dashboard"><img src="\images\logo-1.svg" alt="" style="height: 30px;"></a>
            <a class="navbar-brand" href="\admin\dashboard" style="font-family: serif!important;">MindLink</a>
        }
    </div>

    <div style="display: flex; align-items: center; gap: 8px;">

        @* Профил бутон — само на мобил *@
        <div class="profile-wrapper mobile-only">
            <button class="profile-trigger" @onclick="ToggleProfileDropdown">
                @Session.CurrentUser?.Name
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" style="width: 28px; fill: lightseagreen;">
                    <path d="M463 448.2C440.9 409.8 399.4 384 352 384L288 384C240.6 384 199.1 409.8 177 448.2C212.2 487.4 263.2 512 320 512C376.8 512 427.8 487.3 463 448.2zM64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM320 336C359.8 336 392 303.8 392 264C392 224.2 359.8 192 320 192C280.2 192 248 224.2 248 264C248 303.8 280.2 336 320 336z" />
                </svg>
            </button>
            @if (isProfileDropdownOpen)
            {
                <div class="dropdown-custom">
                    <div @onclick="GoToProfile">Профил</div>
                    <div @onclick="Logout" style="border: none!important;">Изход</div>
                </div>
            }
        </div>

        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        @if (Session.IsLoggedIn && Session.CurrentUser?.RoleId == 1)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/homepage" Match="NavLinkMatch.All">
                    <span class="oi oi-home" aria-hidden="true"></span> Начало
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/archive">
                    <span class="oi oi-book" aria-hidden="true"></span> Архив
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/stats">
                    <span class="oi oi-graph" aria-hidden="true"></span> Статистика
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/resources">
                    <span class="oi oi-layers" aria-hidden="true"></span> Ресурси
                </NavLink>
            </div>
        }
        @if (Session.IsLoggedIn && Session.CurrentUser?.RoleId == 2)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/dashboard">
                    <span class="oi oi-dashboard" aria-hidden="true"></span> Табло
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/users">
                    <span class="oi oi-people" aria-hidden="true"></span> Потребители
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/user-logs">
                    <span class="oi oi-clock" aria-hidden="true"></span> История на влизанията
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin/resources">
                    <span class="oi oi-layers" aria-hidden="true"></span> Ресурси
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isProfileDropdownOpen = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private void ToggleProfileDropdown() => isProfileDropdownOpen = !isProfileDropdownOpen;

    private void GoToProfile()
    {
        isProfileDropdownOpen = false;
        collapseNavMenu = true;
        NavManager.NavigateTo("/myprofile");
    }

    private void Logout()
    {
        isProfileDropdownOpen = false;
        collapseNavMenu = true;
        NavManager.NavigateTo("/login");
    }
}
