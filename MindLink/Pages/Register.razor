@page "/signup"
@inject UserSessionService Session
@inject NavigationManager Nav
@inject MindLink.Data.MindLinkDbContext DbContext
@using MindLink.Data.Models
@using MindLink.Data.Services
@using System.Threading.Tasks
@using Microsoft.AspNetCore.Identity;

<link href="css/mindlink-entry.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-RXf+QSDCUQs7aTbX3eRkQf9g6sW4Q+gX6Mz4L5uB1gY9y+3Vzyd+Zt0q3BqCqXJpUoR6cEm1gsl+8Vf5m7M5xg==" crossorigin="anonymous" referrerpolicy="no-referrer" />


<PageTitle>Регистрирай се в ML</PageTitle>
<div class="registration-form">
	<div class="header">
		<div class="logo">ML</div>
		<h2>Създай акаунт</h2>
		<p class="muted">Започни своето MindLink пътуване ✨</p>
		<i class="fa-solid fa-heart" style="color:red; font-size:24px;"></i>
	</div>
	<div class="auth-container">

		<div class="auth-card-register">

			<form class="auth-form" onsubmit="return false;">
				<div class="fields">
					<label class="inf">Име</label>
					<input class="input-fields @(submitAttempted && !VerifyPassword() ? "input-error" : "")" type="text" placeholder="напр. Иван" @bind-value="@FirstName" />
					@if (submitAttempted && !VerifyFirstName())
					{
						<div class="validation-message">
							Моля, въведете име
						</div>
					}
				</div>

				<div class="fields">
					<label class="inf">Пол</label>
					<div class="gender-form">
						<div class="gender-options">
							<input type="radio" id="contactChoice1" name="gender" @onclick="() => SelectGender('m')" />
							<label style="margin: 0!important;" class="inf" for="genderChoice1">Мъж</label>
							<svg style="height: 25px; margin: 0!important; fill: cornflowerblue;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M384 96C384 78.3 398.3 64 416 64L544 64C561.7 64 576 78.3 576 96L576 224C576 241.7 561.7 256 544 256C526.3 256 512 241.7 512 224L512 173.3L417 268.3C436.5 296.7 448 331 448 368.1C448 465.3 369.2 544.1 272 544.1C174.8 544.1 96 465.2 96 368C96 270.8 174.8 192 272 192C309 192 343.4 203.4 371.8 223L466.8 128L416.1 128C398.4 128 384.1 113.7 384.1 96zM272 480C333.9 480 384 429.9 384 368C384 306.1 333.9 256 272 256C210.1 256 160 306.1 160 368C160 429.9 210.1 480 272 480z" /></svg>
						</div>
						<div class="gender-options">
							<input type="radio" id="contactChoice2" name="gender" @onclick="() => SelectGender('f')"/>
							<label style="margin: 0!important;" class="inf" for="genderChoice2">Жена</label>
							<svg style="height: 25px; margin: 0px 0px 5px 0px!important; fill: hotpink;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Pro v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2026 Fonticons, Inc.--><path d="M208 240C208 178.1 258.1 128 320 128C381.9 128 432 178.1 432 240C432 301.9 381.9 352 320 352C258.1 352 208 301.9 208 240zM351.9 413.1C433.9 398.1 496 326.3 496 240C496 142.8 417.2 64 320 64C222.8 64 144 142.8 144 240C144 326.3 206.1 398.1 288.1 413.1C288 414.1 288 415 288 416L288 480L256 480C238.3 480 224 494.3 224 512C224 529.7 238.3 544 256 544L288 544L288 576C288 593.7 302.3 608 320 608C337.7 608 352 593.7 352 576L352 544L384 544C401.7 544 416 529.7 416 512C416 494.3 401.7 480 384 480L352 480L352 416C352 415 352 414.1 351.9 413.1z" /></svg>
						</div>
					</div>
				</div>

				<div class="fields">
					<label class="inf">Потребителско име</label>
					<input class="input-fields" type="text" placeholder="user_example" @bind-value="@user.Username" />
					@if (submitAttempted && !VerifyUsername())
					{
						<div class="validation-message">
							Потребителското име е задължително
						</div>
					}
				</div>

				<div class="fields">
					<label class="inf">Парола</label>
					<input class="input-fields" type="password" placeholder="••••••••••" value=""/>
					@if (submitAttempted && !VerifyPassword())
					{
						<div class="validation-message">
							Паролата трябва да е поне 12 символа, с главна, малка буква, цифра и символ
						</div>
					}
				</div>

			</form>

		</div>
		<div class="auth-card-register">

			<form class="auth-form" onsubmit="return false;">
				<div class="fields">
					<label class="inf">Фамилия</label>
					<input type="text" placeholder="напр. Петров" @bind-value="@LastName" @oninput="() => VerifyLastName()" required />
				</div>

				<div class="fields">
					<label class="inf">Роля</label>
					<div class="dropdown-field">
						<button class="input-fields dropdown-btn" type="button" @onclick="ToggleDropdown">
							<span class="dropdown-label @(user.RoleId > 0 ? "selected" : "")">@selectedRoleLabel</span>

							<svg class="dropdown-arrow @(isDropdownOpen ? "open" : "")"
								 xmlns="http://www.w3.org/2000/svg"
								 viewBox="0 0 24 24">
								<path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2"
									  stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						@if (isDropdownOpen)
						{
							<div class="dropdown-backdrop" @onclick="CloseDropdown"></div>
						}
						<ul class="dropdown-menu @(isDropdownOpen ? "show" : "")">
							<li @onclick="() => SelectRole(1)">
								<svg style="height: 25px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M80 259.8L289.2 345.9C299 349.9 309.4 352 320 352C330.6 352 341 349.9 350.8 345.9L593.2 246.1C602.2 242.4 608 233.7 608 224C608 214.3 602.2 205.6 593.2 201.9L350.8 102.1C341 98.1 330.6 96 320 96C309.4 96 299 98.1 289.2 102.1L46.8 201.9C37.8 205.6 32 214.3 32 224L32 520C32 533.3 42.7 544 56 544C69.3 544 80 533.3 80 520L80 259.8zM128 331.5L128 448C128 501 214 544 320 544C426 544 512 501 512 448L512 331.4L369.1 390.3C353.5 396.7 336.9 400 320 400C303.1 400 286.5 396.7 270.9 390.3L128 331.4z" /></svg>								
								<span class="dropdown-options">Ученик</span>
							</li>
							<li @onclick="() => SelectRole(2)">
								<svg style="height: 25px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Pro v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2026 Fonticons, Inc.--><path d="M128 160C128 124.7 156.7 96 192 96L544 96C579.3 96 608 124.7 608 160L608 400L512 400L512 384C512 366.3 497.7 352 480 352L416 352C398.3 352 384 366.3 384 384L384 400L254.9 400C265.8 381.2 272 359.3 272 336C272 265.3 214.7 208 144 208C138.6 208 133.2 208.3 128 209L128 160zM333 512C327.9 487.8 316.7 465.9 300.9 448L608 448C608 483.3 579.3 512 544 512L333 512zM64 336C64 291.8 99.8 256 144 256C188.2 256 224 291.8 224 336C224 380.2 188.2 416 144 416C99.8 416 64 380.2 64 336zM0 544C0 491 43 448 96 448L192 448C245 448 288 491 288 544C288 561.7 273.7 576 256 576L32 576C14.3 576 0 561.7 0 544z" /></svg>
@* 								<svg style="height: 25px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M320 312C253.7 312 200 258.3 200 192C200 125.7 253.7 72 320 72C386.3 72 440 125.7 440 192C440 258.3 386.3 312 320 312zM289.5 368L350.5 368C360.2 368 368 375.8 368 385.5C368 389.7 366.5 393.7 363.8 396.9L336.4 428.9L367.4 544L368 544L402.6 405.5C404.8 396.8 413.7 391.5 422.1 394.7C484 418.3 528 478.3 528 548.5C528 563.6 515.7 575.9 500.6 575.9L139.4 576C124.3 576 112 563.7 112 548.6C112 478.4 156 418.4 217.9 394.8C226.3 391.6 235.2 396.9 237.4 405.6L272 544.1L272.6 544.1L303.6 429L276.2 397C273.5 393.8 272 389.8 272 385.6C272 375.9 279.8 368.1 289.5 368.1z" /></svg>
 *@								<span class="dropdown-options">Учител</span>
							</li>
							<li @onclick="() => SelectRole(3)">
								<svg style="height: 25px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M320 312C386.3 312 440 258.3 440 192C440 125.7 386.3 72 320 72C253.7 72 200 125.7 200 192C200 258.3 253.7 312 320 312zM290.3 368C191.8 368 112 447.8 112 546.3C112 562.7 125.3 576 141.7 576L498.3 576C514.7 576 528 562.7 528 546.3C528 447.8 448.2 368 349.7 368L290.3 368z" /></svg>
								<span class="dropdown-options">Друго</span>
							</li>
						</ul>
					</div>
				</div>

				<div class="fields">
					<label class="inf">Дата на раждане</label>
					<input class="input-fields" type="date" @bind-value="user.Birthday">
				</div>

				<div class="fields">
					<label class="inf">Потвърди парола</label>
					<input class="input-fields" type="password" placeholder="••••••••••" value="" @oninput="PasswordInput" required />
				</div>

			</form>
		</div>
	</div>
	<div>
		<button type="submit"
				class="btn primary"
				@onclick="CreateUser">
			Регистрация
		</button>
		<p class="muted small">
			Вече имаш акаунт?
			<a href="/login">Вход</a>
		</p>
	</div>
</div>

@code
{
	private bool submitAttempted = false;

	private string FirstName;
	private string LastName;
	private bool isDropdownOpen = false;
	private string selectedRoleLabel = "- -  Изберете роля  - -";


	private void ToggleDropdown()
	{
		isDropdownOpen = !isDropdownOpen;
	}

	private void CloseDropdown()
	{
		isDropdownOpen = false;
	}

	private void SelectRole(int roleId)
	{
		user.RoleId = roleId;
		selectedRoleLabel = roleId switch
		{
			1 => "Ученик",
			2 => "Учител",
			3 => "Друго",
			_ => "- -  Изберете роля  - -"
		};
		isDropdownOpen = false;
	}

	UsersService _usersService = null!;
	User user = new User();
	private List<User> allUsers = new List<User>();
	bool isValidPassword = false;

	protected override async void OnInitialized()
	{
		_usersService = new UsersService(DbContext);
		user = new User();
		user.Password = "";
		allUsers = await _usersService.GetAllUsers();
	}

	private bool VerifyUser()
	{
		return !(VerifyUsername() && VerifyFirstName() && VerifyRole() && VerifyPassword());
	}

	private bool VerifyUsername()
	{
		return !string.IsNullOrEmpty(user.Username) && user.Username.Length > 5 && !allUsers.Any(x => x.Username == user.Username);
	}

	private bool VerifyPassword()
	{
		return !string.IsNullOrEmpty(user.Password) && user.Password.Length >= 12 && user.Password.Any(char.IsDigit) &&
					user.Password.Any(char.IsLower) && user.Password.Any(char.IsUpper) && user.Password.Any(x => !char.IsLetterOrDigit(x));
	}

	private void PasswordInput(ChangeEventArgs e)
	{
		user.Password = e.Value?.ToString();
	}

	private bool VerifyFirstName()
	{
		return (!string.IsNullOrEmpty(FirstName) && FirstName.Length > 2);
	}

	private bool VerifyLastName()
	{
		return (!string.IsNullOrEmpty(LastName) && LastName.Length>2);
	}

	private bool VerifyRole()
	{
		return user.RoleId > 0;
	}

	private void SelectGender(char gender)
	{
		user.Gender = gender;
	}

	private void CreateUser()
	{
		submitAttempted = true;
		StateHasChanged();
		if(VerifyUser())
		{
			StateHasChanged();
			return;
		}
		else
		{
			user.Name = FirstName.TrimEnd() + " " + LastName.TrimEnd();
			user.UserCode = GenerateUniqueUserCode();
			_usersService.CreateUser(user);
			user = new User();
			Nav.NavigateTo("/success");
		}

	}

	private static string GenerateCode()
	{
		const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
		Random random = new Random();
		return new string(Enumerable.Repeat(chars, 6)
			.Select(s => s[random.Next(s.Length)]).ToArray());
	}

	private string GenerateUniqueUserCode()
	{
		string code;
		do
		{
			code = GenerateCode();
		}
		while (UserCodeExists(code));

		return code;
	}

	private bool UserCodeExists(string code)
	{
		return _usersService.IsCodeExisting(code);
	}
}

<style>
	.input-error {
		border-color: #EF4444;
	}

	.dropdown-btn {
		display: flex;
		align-items: center; /* вертикално центриране */
		justify-content: space-between; /* текст вляво, стрелка вдясно */
		gap: 8px; /* разстояние между текст и стрелка */
		padding: 8px 12px; /* вътрешен отстъп от всички страни */
		width: 100%;
		box-sizing: border-box;
	}

	.dropdown-label {
		color: dimgray;
		font-size: 14px;
		flex-grow: 1; /* текстът заема цялото свободно пространство */
	}

	.dropdown-arrow {
		width: 18px;
		height: 18px;
		color: #777;
		transition: transform 0.25s ease;
		margin-right: 0 !important;
	}

		.dropdown-arrow.open {
			transform: rotate(180deg);
		}

	.dropdown-backdrop {
		position: fixed;
		inset: 0;
		background: transparent;
		z-index: 90;
	}

	.dropdown-field {
		position: relative;
		width: 100%;
	}

	.dropdown-menu {
		position: absolute;
		top: 100%;
		left: 0;
		width: 100%;
		display: none;
		background: #fff;
		border: 1px solid rgba(0,0,0,0.1);
		border-radius: 8px;
		margin-top: 4px;
		z-index: 100;
	}

		.dropdown-menu.show {
			display: block;
		}

		.dropdown-menu li {
			padding: 8px 10px;
			cursor: pointer;
			display: flex;
			align-items: center;
			gap: 10px;
		}

			.dropdown-menu li:hover {
				background: #f0f0f0;
			}


	select,
	::picker(select) {
		appearance: base-select;
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family: "Helvetica", "Arial", sans-serif;
	}


	h2 {
		font-size: 1.2rem;
	}

	.dropdown-field {
		display: flex;
		gap: 10px;
	}

	select {
		flex: 1;
	}

	select {
		border: 1px solid rgba(0, 0, 0, 0.1);
		background: #fff;
		padding: 10px;
		transition: 0.4s;
	}

		select:hover,
		select:focus {
			background: #eee;
		}

		select::picker-icon {
			color: #999999;
			transition: 0.4s rotate;
		}

		select:open::picker-icon {
			rotate: 180deg;
		}

	::picker(select) {
		border: none;
	}

	.role-select {
		height: 37.45px;
	}

	option {
		display: flex;
		justify-content: flex-start;
		gap: 20px;
		border: 1px solid rgba(0, 0, 0, 0.1);
		background: #eeeeee;
		padding: 5px;
		transition: 0.4s;
	}

		option:first-of-type {
			border-radius: 8px 8px 0 0;
		}

		option:last-of-type {
			border-radius: 0 0 8px 8px;
		}

	::picker(select) {
		border-radius: 8px;
	}

	option:not(option:last-of-type) {
		border-bottom: none;
	}

	option:nth-of-type(odd) {
		background: white;
	}

	option:hover,
	option:focus {
		background: plum;
	}

	option .icon {
		font-size: 1.6rem;
	}

	selectedcontent .icon {
		display: none;
	}

	option:checked {
		font-weight: bold;
	}

	::picker(select) {
		opacity: 0;
		transition: all 0.4s allow-discrete;
	}

		::picker(select):popover-open {
			opacity: 1;
		}


	::picker(select) {
		top: calc(anchor(bottom) + 1px);
	}



