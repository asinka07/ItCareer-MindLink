@page "/signup"
@inject UserSessionService Session
@inject NavigationManager Nav
@inject MindLink.Data.MindLinkDbContext DbContext
@using MindLink.Data.Models
@using MindLink.Data.Services

<link href="css/mindlink-register.css" rel="stylesheet" />

<PageTitle>Регистрирай се в ML</PageTitle>

<div class="registration-page">
	<div class="registration-form">

		<div class="header">
			<div class="logo">ML</div>
			<h2>Създай акаунт</h2>
			<p class="muted">Започни своето MindLink пътуване ✨</p>
		</div>

		<div class="auth-container">

			<div class="row-short">
				<div class="field">
					<label>Име</label>
					<input type="text" @bind="FirstName" @bind:event="oninput" placeholder="напр. Иван" />
					@if (submitAttempted && !VerifyFirstName())
					{
						<div class="text-danger">Моля, въведете име (минимум 2 символа)</div>
					}
				</div>
				<div class="field">
					<label>Фамилия</label>
					<input type="text" @bind="LastName" @bind:event="oninput" placeholder="напр. Петров" />
					@if (submitAttempted && !VerifyLastName())
					{
						<div class="text-danger">Моля, въведете фамилия (минимум 2 символа)</div>
					}
				</div>
			</div>

			<div class="row-short">
				<div class="field">
					<label>Дата на раждане</label>
					<input type="date" @bind="user.Birthday" @bind:event="oninput" />
					@if (submitAttempted && !VerifyBirthday())
					{
						<div class="text-danger">Моля, въведете валидна дата</div>
					}
				</div>
				<div class="field">
					<label>Пол</label>
					<div class="gender-options">
						<label>
							<input type="radio" name="gender" checked="@IsMale()" @onclick="() => SelectGender('m')" /> Мъж
						</label>
						<label>
							<input type="radio" name="gender" checked="@IsFemale()" @onclick="() => SelectGender('f')" /> Жена
						</label>
					</div>

					@if (submitAttempted && !VerifyGender())
					{
						<div class="text-danger">Моля, изберете пол</div>
					}
				</div>
			</div>

			<div class="field">
				<label>Потребителско име</label>
				<input type="text" @bind="user.Username" @bind:event="oninput" placeholder="user_example" />
				@if (submitAttempted && !VerifyUsername())
				{
					<div class="text-danger">Потребителското име е задължително и трябва да е уникално</div>
				}
			</div>

			<div class="row-passwords">
				<div class="field">
					<label>Парола</label>
					<div class="password-wrapper">
						<input type="@PasswordInputType" @bind="user.Password" placeholder="••••••••••" />
						<button type="button" class="eye-btn" @onclick="TogglePasswordVisibility">
							@(IsPasswordVisible ? "🙈" : "👁️")
						</button>
					</div>
					@if (submitAttempted && !VerifyPassword())
					{
						<div class="text-danger">
							Паролата трябва да е поне 12 символа и да съдържа главна, малка буква, цифра и символ
						</div>
					}
				</div>

				<!-- Потвърди парола -->
				<div class="field">
					<label>Потвърди парола</label>
					<div class="password-wrapper">
						<input type="@ConfirmPasswordInputType" @bind="ConfirmPassword" placeholder="••••••••••" />
						<button type="button" class="eye-btn" @onclick="ToggleConfirmPasswordVisibility">
							@(IsConfirmPasswordVisible ? "🙈" : "👁️")
						</button>
					</div>
					@if (submitAttempted && !VerifyConfirmPassword())
					{
						<div class="text-danger">Паролите не съвпадат</div>
					}
				</div>
			</div>


			<button class="btn primary" @onclick="CreateUser">
				Регистрация
			</button>

			<p class="muted small">
				Вече имаш акаунт? <a href="/login">Вход</a>
			</p>

		</div>
	</div>
</div>



@code
{
	private bool submitAttempted = false;

	private string FirstName;
	private string LastName;
	private string ConfirmPassword;
	UsersService _usersService = null!;
	User user = new User();
	private List<User> allUsers = new List<User>();
	bool isValidPassword = false;
		private bool IsPasswordVisible = false;
	private bool IsConfirmPasswordVisible = false;
	private string PasswordInputType => IsPasswordVisible ? "text" : "password";
	private string ConfirmPasswordInputType => IsConfirmPasswordVisible ? "text" : "password";

	protected override async Task OnInitializedAsync()
	{
		Session.LogOut();
		_usersService = new UsersService(DbContext);
		allUsers = await _usersService.GetAllUsers();
		user = new User();
		ConfirmPassword = "";
	}

	private async Task CreateUser()
	{
		submitAttempted = true;

		if (!VerifyUser())
		{
			return;
		}

		user.Name = FirstName.Trim() + " " + LastName.Trim();
		user.UserCode = GenerateUniqueUserCode();

		await _usersService.CreateUser(user);

		user = new User();
		FirstName = "";
		LastName = "";
		ConfirmPassword = "";

		Nav.NavigateTo("/success");
	}

	private void TogglePasswordVisibility()
	{
		IsPasswordVisible = !IsPasswordVisible;
	}

	private void ToggleConfirmPasswordVisibility()
	{
		IsConfirmPasswordVisible = !IsConfirmPasswordVisible;
	}

	private static string GenerateCode()
	{
		const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
		Random random = new Random();
		return new string(Enumerable.Repeat(chars, 6)
			.Select(s => s[random.Next(s.Length)]).ToArray());
	}

	private string GenerateUniqueUserCode()
	{
		string code;
		do
		{
			code = GenerateCode();
		}
		while (UserCodeExists(code));

		return code;
	}

	private bool UserCodeExists(string code)
	{
		return _usersService.IsCodeExisting(code);
	}

	private void SelectGender(char gender)
	{
		user.Gender = gender;
	}

	private bool IsMale() => user.Gender == 'm';
	private bool IsFemale() => user.Gender == 'f';

	private bool VerifyUser() =>
		VerifyFirstName() && VerifyLastName() && VerifyBirthday() &&
		VerifyGender() && VerifyUsername() && VerifyPassword() && VerifyConfirmPassword();

	private bool VerifyFirstName() => !string.IsNullOrWhiteSpace(FirstName) && FirstName.Length >= 2;
	private bool VerifyLastName() => !string.IsNullOrWhiteSpace(LastName) && LastName.Length >= 2;
	private bool VerifyBirthday() =>
		user.Birthday != default && (DateTime.Today.Year - user.Birthday.Year) >= 10 && (DateTime.Today.Year - user.Birthday.Year) <= 120; 
	private bool VerifyGender() => user.Gender == 'm' || user.Gender == 'f';
	private bool VerifyUsername() => !string.IsNullOrWhiteSpace(user.Username) && !allUsers.Any(u => u.Username == user.Username);
	private bool VerifyPassword()
	{
		var pw = user.Password?.Trim() ?? "";
		return pw.Length >= 12 &&
			   pw.Any(char.IsUpper) &&
			   pw.Any(char.IsLower) &&
			   pw.Any(char.IsDigit) &&
			   pw.Any(c => !char.IsLetterOrDigit(c));
	}

	private bool VerifyConfirmPassword() =>
		user.Password != null && user.Password == (ConfirmPassword?.Trim() ?? "");
}