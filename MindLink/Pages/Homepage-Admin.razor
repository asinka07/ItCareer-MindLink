@page "/admin-panel"
@using MindLink.Data.Models
@using MindLink.Data.Services
@inject MindLink.Data.MindLinkDbContext DbContext
<link href="css/Homepage.css" rel="stylesheet" />
<link href="css/admin.css" rel="stylesheet" />

<PageTitle>MindLink - Администратор</PageTitle>

<div class="admin-page">
    <div class="users-section">
        <div class="users-header">
            <input type="text" placeholder="Search user..." class="search-input" @bind="SearchStr" @bind:event="oninput" />
            <button class="btn addBtn" @onclick="OpenAddUser">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-circle" style="margin-right: 5px; margin-bottom: 3px;" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                </svg>
                 Add User
            </button>
        </div>

        <table class="users-table">
            <thead>
                <tr>
                    <th>Име</th>
                    <th>Фамилия</th>
                    <th>Username</th>
                    <th>Роля</th>
                    <th>Създаден</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users.Where(x => x.UserCode != "111111"))
                {
                    <tr>
                        @{
                            int index = user.Name.IndexOf(' ');
                            string firstName = user.Name.Substring(0, index);
                            string lastName = user.Name.Substring(index + 1);
                        }
                        <td>@firstName</td>
                        <td>@lastName</td>
                        <td>@user.Username</td>
                        <td>@(user.RoleId == 1 ? "Потребител" : "Администратор")</td>
                        <td>@user.CreatedAt.Date</td>
                        <td>
                            <button class="btn editBtn" @onclick="() => OpenEdit(user)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                </svg>
                            </button>
                            <button class="btn delete-btn" @onclick="() => OpenDelete(user)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                    <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                </svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (isEditOpen)
    {
        <div class="modal-overlay">
            <div class="edit-panel">
                <h3>@(isAdding ? "Добавяне на потребител" : "Редактиране на потребител")</h3>
                <div class="field">
                    <label>Име</label>
                    <input type="text" placeholder="Име" @bind-value="@firstName"/>
                    @if (submitAttempted && !VerifyFirstName())
                    {
                        <div class="text-danger">Моля, въведете име (минимум 2 символа)</div>
                    }
                </div>
                <div class="field">
                    <label>Фамилия</label>
                    <input type="text" placeholder="Фамилия" @bind-value="@lastName" />
                    @if (submitAttempted && !VerifyLastName())
                    {
                        <div class="text-danger">Моля, въведете фамилия (минимум 2 символа)</div>
                    }
                </div>
                <div class="field">
                    <label>Пол</label>
                    <div class="gender-options">
                        <label style="gap: 10px; display: flex!important;">
                            <input type="radio" name="gender" checked="@IsMale()" @onclick="() => SelectGender('m')" /> Мъж
                        </label>
                        <label style="gap: 10px; display: flex!important;">
                            <input type="radio" name="gender" checked="@IsFemale()" @onclick="() => SelectGender('f')" /> Жена
                        </label>
                    </div>
                    @if (submitAttempted && !VerifyGender())
                    {
                        <div class="text-danger">Моля, изберете пол</div>
                    }
                </div>
                <div class="field">
                    <label>Потребителско име</label>
                    <input type="text" placeholder="Потребителско име" @bind-value="@currentUser.Username"/>
                    @if (submitAttempted && !VerifyUsername())
                    {
                        <div class="text-danger">Потребителското име е заето</div>
                    }
                </div>
                <div class="field">
                    <label>Парола</label>
                    <div class="password-wrapper">
                        <input type="@PasswordInputType" @bind="Password" placeholder="••••••••••" />
                        <button type="button" class="eye-btn" @onclick="TogglePasswordVisibility">
                            @(IsPasswordVisible ? "🙈" : "👁️")
                        </button>
                    </div>   
                    @if (submitAttempted && !VerifyPassword())
                    {
                        <div class="text-danger">
                            Паролата трябва да е поне 12 символа и да съдържа главна, малка буква, цифра и символ
                        </div>
                    }
                </div>
                <div class="field">
                    <label>Потвърдете паролата</label>
                    <div class="password-wrapper">
                        <input type="@ConfirmPasswordInputType" @bind="ConfirmPassword" placeholder="••••••••••" />
                        <button type="button" class="eye-btn" @onclick="ToggleConfirmPasswordVisibility">
                            @(IsConfirmPasswordVisible ? "🙈" : "👁️")
                        </button>
                    </div>  
                    @if (submitAttempted && !VerifyConfirmPassword())
                    {
                        <div class="text-danger">Паролите не съвпадат</div>
                    }
                </div>
                <div class="field">
                    <label class="inf">Роля</label>
                    <div class="dropdown-field">
                        <button class="input-fields dropdown-btn" type="button" @onclick="ToggleDropdown">
                            <span class="dropdown-label @(currentUser.RoleId > 0 ? "selected" : "")">@selectedRoleLabel</span>
                            <svg class="dropdown-arrow @(isDropdownOpen ? "open" : "")" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>
                        @if (isDropdownOpen)
                        {
                            <div class="dropdown-backdrop" @onclick="CloseDropdown"></div>
                        }
                        <ul class="dropdown-menu @(isDropdownOpen ? "show" : "")">
                            <li @onclick="() => SelectRole(1)"><span class="dropdown-options">Потребител</span></li>
                            <li @onclick="() => SelectRole(2)"><span class="dropdown-options">Администратор</span></li>
                        </ul>
                    </div>
                    @if (submitAttempted && !VerifyRole())
                    {
                        <div class="text-danger">Изберете роля!</div>
                    }
                </div>
                <div class="edit-actions">
                    <button class="btn saveBtn" @onclick="SaveUser">@(isAdding ? "Добави" : "Запази")</button>
                    <button class="btn cancelBtn" @onclick="CloseEdit">Откажи</button>
                </div>
            </div>
        </div>
    }

    @if (isDeleteOpen)
    {
        <div class="modal-overlay">
            <div class="delete-panel">
                <h3>Изтриване на потребител</h3>
                <p>Сигурни ли сте, че искате да изтриете потребител <strong>@currentUser.Name</strong>?</p>
                <div class="edit-actions">
                    <button class="btn delete-btn" @onclick="ConfirmDelete">Изтрий</button>
                    <button class="btn cancelBtn" @onclick="CloseDelete">Откажи</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
	private bool submitAttempted = false;

	bool isEditOpen = false;
	bool isAdding = false;
	bool isDeleteOpen = false;
	private bool isDropdownOpen = false;
	private string selectedRoleLabel = "- -  Изберете роля  - -";

	string firstName = string.Empty;
	string lastName = string.Empty;

	private string Password;
	private string ConfirmPassword;

	UsersService _usersService = null;
	LogsService _logsService = null;
	User currentUser = new User();
	List<User> users = new List<User>();

	private bool IsPasswordVisible = false;
	private bool IsConfirmPasswordVisible = false;

	private string PasswordInputType => IsPasswordVisible ? "text" : "password";
	private string ConfirmPasswordInputType => IsConfirmPasswordVisible ? "text" : "password";

	private bool IsMale() => currentUser.Gender == 'm';
	private bool IsFemale() => currentUser.Gender == 'f';
    private bool submitAttempted = false;
    bool isEditOpen = false;
    bool isAdding = false;
    bool isDeleteOpen = false;
    private bool isDropdownOpen = false;
    private string selectedRoleLabel = "- -  Изберете роля  - -";
    string firstName = string.Empty;
    string lastName = string.Empty;
    private string Password;
    private string ConfirmPassword;
    UsersService _usersService = null!;
    User currentUser = new User();
    List<User> users = new List<User>();
    List<User> allUsers = new List<User>();
    private bool IsPasswordVisible = false;
    private bool IsConfirmPasswordVisible = false;
    private string PasswordInputType => IsPasswordVisible ? "text" : "password";
    private string ConfirmPasswordInputType => IsConfirmPasswordVisible ? "text" : "password";
    private string searchStr;
    private string SearchStr { get => searchStr; set { searchStr = value; _ = Search(); } }
    private bool IsMale() => currentUser.Gender == 'm';
    private bool IsFemale() => currentUser.Gender == 'f';

	private string searchStr;

	private string SearchStr
	{
		get => searchStr;
		set
		{
			searchStr = value;
			_ = Search();
		}
	}

	protected override async void OnInitialized()
	{
		base.OnInitialized();
		_usersService = new UsersService(DbContext);
		_logsService = new LogsService(DbContext);
		users = await _usersService.GetAllUsers();
		StateHasChanged();
	}
    protected override async void OnInitialized()
    {
        base.OnInitialized();
        _usersService = new UsersService(DbContext);
        allUsers = await _usersService.GetAllUsers();
        users = new List<User>(allUsers);
        StateHasChanged();
    }

    void OpenEdit(User user)
    {
        currentUser = user;
        int index = user.Name.IndexOf(' ');
        firstName = user.Name.Substring(0, index);
        lastName = user.Name.Substring(index + 1);
        isAdding = false;
        isEditOpen = true;
    }

    void OpenAddUser()
    {
        currentUser = new User();
        firstName = string.Empty;
        lastName = string.Empty;
        isAdding = true;
        isEditOpen = true;
    }

    void CloseEdit()
    { 
        isEditOpen = false;
        submitAttempted = false;
        StateHasChanged();
    }

	async void SaveUser()
	{
		submitAttempted = true; 

		if (!VerifyUser())
			return;

		currentUser.Password = Password;;

		if (isAdding)
		{
			currentUser.Name = firstName + " " + lastName;
			currentUser.UserCode = GenerateUniqueUserCode();
			await _usersService.CreateUser(currentUser);
			await _logsService.CreateLog(currentUser, "Успешно създаден потребител от Админ");
			users.Add(currentUser);
		}
		else
		{
			currentUser.Name = firstName + " " + lastName;
			await _usersService.UpdateUser(currentUser);
			await _usersService.UpdatePassword(currentUser);
			await _logsService.CreateLog(currentUser, "Успешно променени данни от Админ");
		}
		submitAttempted = false;
		isEditOpen = false;
		StateHasChanged();
	}
    async void SaveUser()
    {
        submitAttempted = true; 
        if (!VerifyUser()) return;
        currentUser.Password = Password;
        currentUser.UserCode = GenerateUniqueUserCode();
        currentUser.Name = firstName + " " + lastName;
        if (isAdding)
        {
            await _usersService.CreateUser(currentUser);
            allUsers.Add(currentUser);
        }
        else
        {
            await _usersService.UpdateUser(currentUser);
        }
        users = new List<User>(allUsers);
        isEditOpen = false;
        submitAttempted = false;
        StateHasChanged();
    }

    private static string GenerateCode()
    {
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        Random random = new Random();
        return new string(Enumerable.Repeat(chars, 6).Select(s => s[random.Next(s.Length)]).ToArray());
    }

    private string GenerateUniqueUserCode()
    {
        string code;
        do { code = GenerateCode(); } while (UserCodeExists(code));
        return code;
    }

    private bool UserCodeExists(string code) => _usersService.IsCodeExisting(code);

    async Task Search()
    {
        if (!string.IsNullOrWhiteSpace(searchStr))
        {
            users = allUsers.Where(u => u.Name.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
                                        u.Username.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
                                        u.Role.Name.Contains(searchStr, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        else
        {
            users = new List<User>(allUsers);
        }
        StateHasChanged();
    }

    void OpenDelete(User user) { currentUser = user; isDeleteOpen = true; }
    void CloseDelete() => isDeleteOpen = false;

    async void ConfirmDelete()
    {
        users.Remove(currentUser);
        await _usersService.DeleteUser(currentUser);
		await _logsService.CreateLog(currentUser, "Успешно изтрит от Админ");
        isDeleteOpen = false;
    }


	private void ToggleDropdown()
	{
		isDropdownOpen = !isDropdownOpen;
	}

	private void CloseDropdown()
	{
		isDropdownOpen = false;
	}

	private void SelectRole(int roleId)
	{
		currentUser.RoleId = roleId;
		selectedRoleLabel = roleId switch
		{
			1 => "Потребител",
			2 => "Администратор",
			_ => "- -  Изберете роля  - -"
		};
		isDropdownOpen = false;
	}


private void TogglePasswordVisibility()
{
	IsPasswordVisible = !IsPasswordVisible;
}

private void ToggleConfirmPasswordVisibility()
{
	IsConfirmPasswordVisible = !IsConfirmPasswordVisible;
}

private void SelectGender(char gender)
	{
		currentUser.Gender = gender;
	}

    private bool VerifyUser() =>
    VerifyFirstName() && VerifyLastName() && VerifyGender() &&
    VerifyUsername() && VerifyPassword() && VerifyConfirmPassword() && VerifyRole();
    void ConfirmDelete() { users.Remove(currentUser); allUsers.Remove(currentUser); _usersService.DeleteUser(currentUser); isDeleteOpen = false; }
    private void ToggleDropdown() { isDropdownOpen = !isDropdownOpen; }
    private void CloseDropdown() { isDropdownOpen = false; }
    private void SelectRole(int roleId) { currentUser.RoleId = roleId; selectedRoleLabel = roleId switch { 1 => "Потребител", 2 => "Администратор", _ => "- -  Изберете роля  - -" }; isDropdownOpen = false; }
    private void TogglePasswordVisibility() { IsPasswordVisible = !IsPasswordVisible; }
    private void ToggleConfirmPasswordVisibility() { IsConfirmPasswordVisible = !IsConfirmPasswordVisible; }
    private void SelectGender(char gender) { currentUser.Gender = gender; }

    private bool VerifyUser() => VerifyFirstName() && VerifyLastName() && VerifyGender() && VerifyUsername() && VerifyPassword() && VerifyConfirmPassword() && VerifyRole();
    private bool VerifyFirstName() => !string.IsNullOrWhiteSpace(firstName) && firstName.Length >= 2;
    private bool VerifyLastName() => !string.IsNullOrWhiteSpace(lastName) && lastName.Length >= 2;
    private bool VerifyGender() => currentUser.Gender == 'm' || currentUser.Gender == 'f';
    private bool VerifyUsername() => !string.IsNullOrWhiteSpace(currentUser.Username) && !users.Any(u => u.Username == currentUser.Username && u != currentUser);
    private bool VerifyRole() => selectedRoleLabel != "- -  Изберете роля  - -";
    private bool VerifyPassword() { var pw = Password?.Trim() ?? ""; return pw.Length >= 12 && pw.Any(char.IsUpper) && pw.Any(char.IsLower) && pw.Any(char.IsDigit) && pw.Any(c => !char.IsLetterOrDigit(c)); }
    private bool VerifyConfirmPassword() => (Password?.Trim() ?? "") == (ConfirmPassword?.Trim() ?? "");
}
