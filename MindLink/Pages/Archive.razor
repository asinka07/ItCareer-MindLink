@page "/archive"

@inject UserSessionService Session
@inject NavigationManager Nav
@inject MindLink.Data.MindLinkDbContext DbContext
@inject IJSRuntime JS
@using MindLink.Data.ViewModels
@using MindLink.Data.Models
@using MindLink.Data.Services

<link href="/css/Homepage.css" rel="stylesheet" />
<link href="/css/site.css" rel="stylesheet" />
<link href="/css/MyProfile.css" rel="stylesheet" />
<script src="/js/book.js"></script>

<PageTitle>MindLink - Начало</PageTitle>

@if (bookPages.Count > 0)
{
    <div style="display: flex; flex-direction: column;">
    <div id="book" class="book">
        <!-- Предна корица -->
        <div class="paper hard">
            <div class="front">
                <div class="front-content">
                    <h1>Дневникът на @Session.CurrentUser?.Name</h1>
                </div>
            </div>
            <div class="back"></div>
        </div>

        @foreach (var bookPage in bookPages)
        {
            <div class="paper">
                <div class="front">
                    <div class="front-content">
                        @if (bookPage.LeftRecord != null)
                        {
                            <p>@bookPage.LeftRecord.RecordDate.ToString("dd/MM/yyyy")</p>
                            <hr />
                            <p>@bookPage.LeftRecord.RecordText</p>
                        }
                    </div>
                </div>
                <div class="back">
                    <div class="back-content">
                        @if (bookPage.RightRecord != null)
                        {
                            <p>@bookPage.RightRecord.RecordDate.ToString("dd/MM/yyyy")</p>
                            <hr />
                            <p>@bookPage.RightRecord.RecordText</p>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Задна корица -->
        <div class="paper hard">
            <div class="front"></div>
            <div class="back"></div>
        </div>
    </div>


<div class="book-controls">
    <button id="prev-btn">&#x2190; Previous page</button>
    <button id="next-btn">Next page &#x2192;</button>
</div>
            </div>

}
else
{
    <h5>Няма записи</h5>
}


@code {
    private List<BookPage> bookPages = new();
        RecordsService _recordsService = null!;
    List<Record> records = new List<Record>();

    int count = 0;
    private void BuildBook()
{
    bookPages.Clear();

    for (int i = 0; i < records.Count; i += 2)
    {
        var page = new BookPage
        {
            LeftRecord = records[i],
            RightRecord = (i + 1 < records.Count) ? records[i + 1] : null
        };

        bookPages.Add(page);
    }
}


    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
    {
        Nav.NavigateTo("/login");
        return;
    }

    _recordsService = new RecordsService(DbContext);

    records = (await _recordsService.GetAllRecordsByUser(Session.CurrentUser!.UserCode)).OrderBy(r => r.RecordDate).ToList();
    BuildBook();
    }

}

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Книгата */
.book {
    position: relative;
    width: 350px;
    height: 500px;
}

/* Страници */
.paper {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    perspective: 3500px;
}

.front,
.back {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    transform-origin: left center;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.7s ease;
    font-family: 'Georgia', serif;
    font-size: 1.2rem;
    line-height: 1.4;
    transform-style: preserve-3d;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
        border-radius: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
}

/* Предна страница */
.front {
    z-index: 1;
    background-image: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(245,245,235,0.95)), url('images/paper-texture.png');
    background-blend-mode: multiply;
    border-radius: 2px;
    margin-left: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
    backface-visibility: hidden;

}

/* Задна страница */
.back {
    z-index: 0;
    background-image: url('images/paper-texture.png');
    background-blend-mode: multiply;
    border-radius: 2px;
    margin-right: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
}

/* Съдържание на страница */
.front-content,
.back-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
}

/* Задно съдържание обръщане */
.back-content {
    transform: rotateY(180deg);
}

/* Flip ефект */
.flipped .front {
    transform: rotateY(-180deg);
    box-shadow: inset -15px 0 30px rgba(0,0,0,0.15);
}

.flipped .back {
    transform: rotateY(-180deg);
    box-shadow: inset 15px 0 30px rgba(0,0,0,0.15);
}

/* Корици (предна и задна) */
.paper.hard .front,
.paper.hard .back {
    background-image: linear-gradient(180deg, rgba(189,255,254,0.9), rgba(157,242,163,0.9)), url('images/cover-texture.png');
    background-blend-mode: multiply;
    color: #fff;
    font-weight: bold;
    border-radius: 12px;
    box-shadow: inset 0 0 0 4px rgba(0,60,0,0.4), 0 15px 30px rgba(0,0,0,0.4);
    transform-origin: left center;
    width: calc(100% + 5px);
    height: calc(100% + 10px);
    top: -5px;
    left: 10px;
}

/* Останалите страници леко по-малки от корицата */
.paper:not(.hard) {
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s;
    width: calc(100% - 20px);
    height: calc(100% - 20px);
    top: 10px;
    left: 10px;
}

.paper:not(.hard) .front,
.paper:not(.hard) .back {
    box-shadow: inset -4px 0 6px rgba(0,0,0,0.08);
    border-left: 2px solid rgba(74,110,110,0.4);
}

.paper.hard {
    z-index: 1000;
}

.paper.flipped {
    z-index: auto; 
}

.book {
    perspective: 2000px; 
}

/* Стил на бутоните за разлистване */
#prev-btn,
#next-btn {
    position: relative;
    background-color: #10B981; /* Emerald green */
    color: #fff;
    font-weight: bold;
    border: none;
    padding: 10px 10px;
    margin: 10px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    transition: transform 0.3s ease, background-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 5px 10px rgba(0,0,0,0.15);
}

/* Hover ефект */
#prev-btn:hover,
#next-btn:hover {
    background-color: #34D399; /* lighter green */
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 15px rgba(0,0,0,0.2);
}

/* Натискане на бутон */
#prev-btn:active,
#next-btn:active {
    transform: translateY(1px) scale(0.98);
    box-shadow: 0 4px 8px rgba(0,0,0,0.15);
}

#prev-btn i,
#next-btn i {
    font-size: 1.5rem;
    vertical-align: middle;
    margin-right: 5px;
}

.book-controls {
    display: flex;
    justify-content: center; 
    gap: 20px; 
    margin-top: 15px;
}
</style>

@code{
protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        await JS.InvokeVoidAsync("initializeBook");
    }
}

}