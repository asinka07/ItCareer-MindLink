@page "/archive"
@attribute [Authorize(Roles = "User")]
@inject UserSessionService Session
@inject NavigationManager Nav
@inject MindLink.Data.MindLinkDbContext DbContext
@using MindLink.Data.Models
@using MindLink.Data.ViewModels
@using MindLink.Data.Services
@namespace MindLink.Components
@inject IJSRuntime JS

<link href="/css/book.css" rel="stylesheet" />

<h3>Архив на дневниците</h3>

@if (monthlyRecords.Any())
{
    <div class="book-thumbnails-wrapper">
    <div class="book-thumbnails">
        @foreach (var month in monthlyRecords.OrderByDescending(m => m.Key))
        {
            @foreach (var bookPages in month.Value)
            {
                <div class="book-thumbnail" style="margin-right: 15px; " @onclick="() => OpenBook(bookPages, month.Key)">
                    <div class="paper hard" style="box-shadow: none!important;">
                        <div class="front" style="box-shadow: none!important; border: 1px solid darkgreen;"><div class="front-content">@month.Key.ToString("MMMM yyyy")</div></div>
                        <div class="back" style="box-shadow: none!important;"></div>
                    </div>
                </div>
            }
        }
    </div>
</div>
}
else
{
    <p>Няма записи</p>
}

@if (selectedBook != null)
{
    <Book @ref="bookComponent" Title="@selectedBookTitle" Pages="@selectedBook.Pages" />
}

@code {
    private Book? bookComponent;
    private RecordsService _recordsService = null!;
    private List<Record> records = new List<Record>();

    private Dictionary<DateTime, List<BookViewModel>> monthlyRecords = new();
    private BookViewModel? selectedBook;
    private string selectedBookTitle = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        _recordsService = new RecordsService(DbContext);
        records = (await _recordsService.GetAllRecordsByUser(Session.CurrentUser!.UserCode))
                    .OrderBy(r => r.RecordDate).ToList();

        monthlyRecords = records
            .GroupBy(r => new DateTime(r.RecordDate.Year, r.RecordDate.Month, 1))
            .ToDictionary(
                g => g.Key,
                g => new List<BookViewModel> { new BookViewModel { Pages = BuildBookPages(g.ToList()) } }
            );
    }

private void OpenBook(BookViewModel book, DateTime month)
{
    selectedBook = book;
    selectedBookTitle = $"Дневник за {month:MMMM yyyy}";

    StateHasChanged(); 
    _ = InvokeAsync(() => bookComponent?.NotifyBookOpened());
}


    private List<BookPage> BuildBookPages(List<Record> records)
    {
        var pages = new List<BookPage>();
        for (int i = 0; i < records.Count; i += 2)
        {
            pages.Add(new BookPage
            {
                LeftRecord = records[i],
                RightRecord = (i + 1 < records.Count) ? records[i + 1] : null
            });
        }
        return pages;
    }

    public class BookViewModel
    {
        public List<BookPage> Pages { get; set; } = new();
    }
}

<style>
    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.book {
    color: darkgreen;
    position: relative;
    width: 350px;
    height: 500px;
}

.paper {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    perspective: 3500px;
}

.front,
.back {
    color: darkgreen;
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    transform-origin: left center;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.7s ease;
    font-family: 'Georgia', serif;
    font-size: 1.2rem;
    line-height: 1.4;
    transform-style: preserve-3d;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    border-radius: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
}

.front {
    z-index: 1;
    background-image: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(245,245,235,0.95)), url('images/paper-texture.png');
    background-blend-mode: multiply;
    border-radius: 2px;
    margin-left: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
    backface-visibility: hidden;
}

.back {
    z-index: 0;
    background-image: url('images/paper-texture.png');
    background-blend-mode: multiply;
    border-radius: 2px;
    margin-right: 2px;
    box-shadow: 0 5px 0 rgba(0,0,0,0.03);
}

.front-content,
.back-content {
    color: darkgreen;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.back-content {
    transform: rotateY(180deg);
}

.flipped .front {
    transform: rotateY(-180deg);
    box-shadow: inset -15px 0 30px rgba(0,0,0,0.15);
}

.flipped .back {
    transform: rotateY(-180deg);
    box-shadow: inset 15px 0 30px rgba(0,0,0,0.15);
}

.paper.hard .front,
.paper.hard .back {
    background-image: linear-gradient(180deg, rgba(189,255,254,0.9), rgba(157,242,163,0.9)), url('images/cover-texture.png');
    background-blend-mode: multiply;
    color: #fff;
    font-weight: bold;
    border-radius: 12px;
    box-shadow: inset 0 0 0 4px rgba(0,60,0,0.4), 0 15px 30px rgba(0,0,0,0.4);
    transform-origin: left center;
    width: calc(100% + 5px);
    height: calc(100% + 10px);
    top: -5px;
    left: 10px;
}

.paper:not(.hard) {
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s;
    width: calc(100% - 20px);
    height: calc(100% - 20px);
    top: 10px;
    left: 10px;
}

    .paper:not(.hard) .front,
    .paper:not(.hard) .back {
        box-shadow: inset -4px 0 6px rgba(0,0,0,0.08);
        border-left: 2px solid rgba(74,110,110,0.4);
    }

.paper.hard {
    z-index: 1000;
}

.paper.flipped {
    z-index: auto;
}

.book {
    perspective: 2000px;
}


.book-thumbnail {
    flex: 0 0 auto;
    width: 80px;
    height: 120px;
    cursor: pointer;
    perspective: 1000px;
    scroll-snap-align: start;
}

.book-thumbnails-wrapper {
    overflow-x: auto;
    padding: 15px;
    margin-bottom: 20px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
}

.book-thumbnails {
    display: flex;
    gap: 15px;
}

.book-thumbnail {
    flex: 0 0 auto;
    width: 80px;
    height: 120px;
    cursor: pointer;
    perspective: 1000px;
    scroll-snap-align: start;
}

</style>