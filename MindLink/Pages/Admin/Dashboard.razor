@attribute [Authorize]
@page "/admin/dashboard"
@using MindLink.Data.Services
@inject NavigationManager Nav
@inject UserSessionService Session
@inject DashboardService DashboardService
<link href="css/Homepage.css" rel="stylesheet" />
<link href="css/admin.css" rel="stylesheet" />
<link href="css/adminDashboard.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<h1 class="page-title">Табло</h1>
<p class="subtitle">Преглед на активността в системата за последните 30 дни.</p>

@if (isLoading)
{
    <div class="loading-wrap">
        <div class="spinner"></div>
        <span>Зареждане...</span>
    </div>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon users-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@totalUsers</span>
                <span class="stat-label">Общо потребители</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon records-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z" />
                    <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8m0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5" />
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@totalRecords</span>
                <span class="stat-label">Записи (30 дни)</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon resources-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783" />
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@activeResources</span>
                <span class="stat-label">Активни ресурси</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon logs-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z" />
                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0" />
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@loginsToday</span>
                <span class="stat-label">Влизания днес</span>
            </div>
        </div>
    </div>

    <div class="charts-row">

        <div class="chart-card">
            <h2 class="chart-title">Разпределение на емоциите</h2>
            <p class="chart-subtitle">Записи по тип настроение — последните 30 дни</p>
            <div class="donut-container">
                <canvas id="emotionChart"></canvas>
            </div>
            <div class="donut-legend">
                <div class="legend-item">
                    <span class="legend-dot" style="background:#9df2a3"></span>
                    <span class="legend-text">Позитивно</span>
                    <span class="legend-count">@emotionCounts.Positive</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background:#ffd296"></span>
                    <span class="legend-text">Неутрално</span>
                    <span class="legend-count">@emotionCounts.Neutral</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background:#ff9696"></span>
                    <span class="legend-text">Негативно</span>
                    <span class="legend-count">@emotionCounts.Negative</span>
                </div>
            </div>
        </div>

        <div class="chart-card chart-card--wide">
            <h2 class="chart-title">Активност по дни</h2>
            <p class="chart-subtitle">Брой записи за последните 7 дни</p>
            <div class="bar-container">
                <canvas id="activityChart"></canvas>
            </div>
        </div>

    </div>

    <div class="bottom-row">

        <div class="table-card">
            <h2 class="chart-title">Най-активни потребители</h2>
            <p class="chart-subtitle">По брой записи през последните 30 дни</p>
            <table class="users-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Потребител</th>
                        <th>Записи</th>
                        <th>Настроение</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var u in topUsers)
                    {
                        <tr>
                            <td><span class="rank-badge">@rank</span></td>
                            <td>@u.Name</td>
                            <td><strong>@u.RecordCount</strong></td>
                            <td>
                                <span class="badge @(u.TopEmotion switch {
                                    "Позитивно" => "positive",
                                    "Неутрално" => "neutral",
                                    "Негативно" => "negative",
                                    _ => "neutral"
                                })">@u.TopEmotion</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>

    </div>
}

@code {
    private bool isLoading = true;

    private int totalUsers;
    private int totalRecords;
    private int activeResources;
    private int loginsToday;

    private EmotionCountsDto emotionCounts = new();
    private List<DayActivityDto> weeklyActivity = new();
    private List<TopUserDto> topUsers = new();
    private List<RecentLogDto> recentLogs = new();

    protected override async Task OnInitializedAsync()
    {
        
    if (Session?.CurrentUser?.RoleId != 2 || Session?.CurrentUser == null)
    {
        Nav.NavigateTo(Nav.HistoryEntryState, true);
    }
        totalUsers      = await DashboardService.GetTotalUsersAsync();
        totalRecords    = await DashboardService.GetRecordsThisMonthAsync();
        activeResources = await DashboardService.GetActiveResourcesAsync();
        loginsToday     = await DashboardService.GetLoginsTodayAsync();
        emotionCounts   = await DashboardService.GetEmotionCountsAsync();
        weeklyActivity  = await DashboardService.GetWeeklyActivityAsync();
        topUsers        = await DashboardService.GetTopUsersAsync();
        recentLogs      = await DashboardService.GetRecentLogsAsync();

        isLoading = false;
            StateHasChanged();

    }

private bool chartsRendered = false;

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (!isLoading && !chartsRendered)
    {
        chartsRendered = true;
        await RenderChartsAsync();
    }
}

    private async Task RenderChartsAsync()
    {
        var emotionData   = new[] { emotionCounts.Positive, emotionCounts.Neutral, emotionCounts.Negative };
        var emotionColors = new[] { "#9df2a3", "#ffd296", "#ff9696" };
        var emotionLabels = new[] { "Позитивно", "Неутрално", "Негативно" };

        await JS.InvokeVoidAsync("renderDoughnutChartAdmin", "emotionChart",
            emotionLabels, emotionData, emotionColors, emotionCounts.Total);

        var barLabels = weeklyActivity.Select(d => d.Label).ToArray();
        var barData   = weeklyActivity.Select(d => d.Count).ToArray();

        await JS.InvokeVoidAsync("renderBarChartAdmin", "activityChart", barLabels, barData);
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}


<script>
    window.renderDoughnutChartAdmin = (canvasId, labels, data, colors, total) => {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const existing = Chart.getChart(canvas);
    if (existing) existing.destroy();

    new Chart(canvas, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: colors,
                borderWidth: 3,
                borderColor: '#fff',
                hoverOffset: 6
            }]
        },
        options: {
            cutout: '72%',
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.label}: ${ctx.parsed}`
                    }
                }
            }
        },
        plugins: [{
            id: 'centerText',
            afterDraw(chart) {
                const { ctx, chartArea: { width, height, left, top } } = chart;
                ctx.save();
                const cx = left + width / 2;
                const cy = top + height / 2;
                ctx.font = 'bold 22px sans-serif';
                ctx.fillStyle = '#1F2937';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(total, cx, cy - 8);
                ctx.font = '12px sans-serif';
                ctx.fillStyle = '#9CA3AF';
                ctx.fillText('записа', cx, cy + 12);
                ctx.restore();
            }
        }]
    });
};

window.renderBarChartAdmin = (canvasId, labels, data) => {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const existing = Chart.getChart(canvas);
    if (existing) existing.destroy();

    new Chart(canvas, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Записи',
                data: data,
                backgroundColor: '#decffc',
                borderRadius: 8,
                borderSkipped: false,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.parsed.y} записа`
                    }
                }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: { color: '#9CA3AF', font: { size: 12 } }
                },
                y: {
                    beginAtZero: true,
                    grid: { color: '#decffc' },
                    ticks: {
                        color: '#9CA3AF',
                        font: { size: 12 },
                        stepSize: 1,
                        precision: 0
                    }
                }
            }
        }
    });
};
</script>
