@attribute [Authorize]
@page "/admin/users"
@using MindLink.Data.Models
@using MindLink.Data.Services
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject UserSessionService Session
@inject MindLink.Data.MindLinkDbContext DbContext
<link href="css/Homepage.css" rel="stylesheet" />
<link href="css/admin.css" rel="stylesheet" />

<PageTitle>MindLink - Администратор</PageTitle>

<h1 class="page-title">Потребители</h1>

<div class="admin-page">
    <div class="users-section">
        <div class="users-header">
            <input type="text" placeholder="Търси потребител..." class="search-input"
                   @bind="SearchStr" @bind:event="oninput" />
            <button class="btn addBtn" @onclick="OpenAddUser">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-circle" style="margin-right: 5px; margin-bottom: 3px;" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4" />
                </svg>
                Добави потребител
            </button>
        </div>

        <table class="users-table">
            <thead>
                <tr>
                    <th>Име</th>
                    <th>Фамилия</th>
                    <th>Username</th>
                    <th>Роля</th>
                    <th>Създаден</th>
                    <th style="text-align: right;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (users.Any())
                {
                    @foreach (var user in users.Where(x => x.UserCode != "111111"))
                    {
                        <tr>
                            @{
                                var names = user.Name.Split(' ', 2);
                                string firstNameCell = names[0];
                                string lastNameCell = names.Length > 1 ? names[1] : "";
                            }
                            <td>@firstNameCell</td>
                            <td>@lastNameCell</td>
                            <td>@user.Username</td>
                            <td>@(user.RoleId == 1 ? "Потребител" : "Администратор")</td>
                            <td>@user.CreatedAt.Date.ToShortDateString()</td>
                            <td style="text-align: right;">
                                <button class="btn editBtn" @onclick="() => OpenEdit(user)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
                                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                    </svg>
                                </button>
                                <button class="btn delete-btn" @onclick="() => OpenDelete(user)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                        <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align:center; color:#9CA3AF; padding: 24px;">Няма записи</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ─── ADD / EDIT MODAL ─── *@
    @if (isEditOpen)
    {
        <div class="modal-overlay">
            <div class="resource-panel">
                <div class="panel-header">
                    <h3>@(isAdding ? "Добавяне на потребител" : "Редактиране на потребител")</h3>
                    <button class="close-btn" @onclick="CloseEdit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                        </svg>
                    </button>
                </div>

                <div class="panel-body">

                    @* ── Name row ── *@
                    <div class="form-row">
                        <div class="form-group half">
                            <label>Име @(isAdding ? "" : "")<span class="required">*</span></label>
                            <input type="text" class="form-input @(submitAttempted && !VerifyFirstName() ? "input-error" : "")"
                                   placeholder="Въведете име..." @bind="firstName" />
                            @if (submitAttempted && !VerifyFirstName())
                            {
                                <span class="field-error">Минимум 2 символа</span>
                            }
                        </div>
                        <div class="form-group half">
                            <label>Фамилия <span class="required">*</span></label>
                            <input type="text" class="form-input @(submitAttempted && !VerifyLastName() ? "input-error" : "")"
                                   placeholder="Въведете фамилия..." @bind="lastName" />
                            @if (submitAttempted && !VerifyLastName())
                            {
                                <span class="field-error">Минимум 2 символа</span>
                            }
                        </div>
                    </div>

                    @* ── Gender ── *@
                    <div class="form-group">
                        <label>Пол <span class="required">*</span></label>
                        <div class="gender-options">
                            <label class="gender-label">
                                <input type="radio" name="gender" checked="@IsMale()" @onclick="() => SelectGender('m')" />
                                Мъж
                            </label>
                            <label class="gender-label">
                                <input type="radio" name="gender" checked="@IsFemale()" @onclick="() => SelectGender('f')" />
                                Жена
                            </label>
                        </div>
                        @if (submitAttempted && !VerifyGender())
                        {
                            <span class="field-error">Изберете пол</span>
                        }
                    </div>

                    @* ── Username ── *@
                    <div class="form-group">
                        <label>Потребителско име <span class="required">*</span></label>
                        <input type="text" class="form-input @(submitAttempted && !VerifyUsername() ? "input-error" : "")"
                               placeholder="Въведете потребителско име..." @bind="currentUser.Username" />
                        @if (submitAttempted && !VerifyUsername())
                        {
                            <span class="field-error">
                                @(string.IsNullOrWhiteSpace(currentUser.Username)
                                    ? "Потребителското име е задължително"
                                    : "Потребителското име е заето")
                            </span>
                        }
                    </div>

                    @* ── Role ── *@
                    <div class="form-group">
                        <label>Роля <span class="required">*</span></label>
                        <div class="dropdown-field">
                            <button class="form-input dropdown-btn" type="button" @onclick="ToggleDropdown">
                                <span class="dropdown-label @(currentUser.RoleId > 0 ? "selected" : "")">@selectedRoleLabel</span>
                                <svg class="dropdown-arrow @(isDropdownOpen ? "open" : "")" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                    <path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                            @if (isDropdownOpen)
                            {
                                <div class="dropdown-backdrop" @onclick="CloseDropdown"></div>
                                <ul class="dropdown-menu show">
                                    <li @onclick="() => SelectRole(1)"><span class="dropdown-options">Потребител</span></li>
                                    <li @onclick="() => SelectRole(2)"><span class="dropdown-options">Администратор</span></li>
                                </ul>
                            }
                        </div>
                        @if (submitAttempted && !VerifyRole())
                        {
                            <span class="field-error">Изберете роля</span>
                        }
                    </div>

                    @* ── Password section ── *@
                    <div class="password-section">
                        <div class="password-section-label">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2" />
                            </svg>
                            @if (isAdding)
                            {
                                <span>Парола <span class="required">*</span></span>
                            }
                            else
                            {
                                <span>Промяна на парола <span class="optional-hint">(незадължително — попълнете само ако искате да смените паролата)</span></span>
                            }
                        </div>

                        <div class="form-row">
                            <div class="form-group half">
                                <label>Парола @(isAdding ? "" : "")</label>
                                <div class="password-wrapper">
                                    <input type="@PasswordInputType"
                                           class="form-input @(submitAttempted && !VerifyPassword() ? "input-error" : "")"
                                           @bind="Password" placeholder="••••••••••" />
                                    <button type="button" class="eye-btn" @onclick="TogglePasswordVisibility">
                                        @(IsPasswordVisible ? "🙈" : "👁️")
                                    </button>
                                </div>
                                @if (submitAttempted && !VerifyPassword())
                                {
                                    <span class="field-error">
                                        @if (isAdding || !string.IsNullOrEmpty(Password))
                                        {
                                            <text>Мин. 12 символа, главна, малка буква, цифра и символ</text>
                                        }
                                    </span>
                                }
                            </div>
                            <div class="form-group half">
                                <label>Потвърдете паролата</label>
                                <div class="password-wrapper">
                                    <input type="@ConfirmPasswordInputType"
                                           class="form-input @(submitAttempted && !VerifyConfirmPassword() ? "input-error" : "")"
                                           @bind="ConfirmPassword" placeholder="••••••••••" />
                                    <button type="button" class="eye-btn" @onclick="ToggleConfirmPasswordVisibility">
                                        @(IsConfirmPasswordVisible ? "🙈" : "👁️")
                                    </button>
                                </div>
                                @if (submitAttempted && !VerifyConfirmPassword())
                                {
                                    <span class="field-error">Паролите не съвпадат</span>
                                }
                            </div>
                        </div>
                    </div>

                </div>

                <div class="panel-footer">
                    <button class="btn saveBtn" @onclick="SaveUser">@(isAdding ? "Добави" : "Запази")</button>
                    <button class="btn cancelBtn" @onclick="CloseEdit">Откажи</button>
                </div>
            </div>
        </div>
    }

    @* ─── DELETE MODAL ─── *@
    @if (isDeleteOpen)
    {
        <div class="modal-overlay" style="justify-content: center!important;">
            <div class="delete-panel">
                <div class="delete-icon-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                        <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                    </svg>
                </div>
                <h3>Изтриване на потребител</h3>
                <p>Сигурни ли сте, че искате да изтриете потребител <strong>@currentUser.Name</strong>?<br /><span class="warn-text">Това действие е необратимо.</span></p>
                <div class="edit-actions">
                    <button class="btn delete-btn" @onclick="ConfirmDelete">Изтрий</button>
                    <button class="btn cancelBtn" @onclick="CloseDelete">Откажи</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool submitAttempted = false;
    private bool isEditOpen = false;
    private bool isAdding = false;
    private bool isDeleteOpen = false;
    private bool isDropdownOpen = false;
    private string selectedRoleLabel = "-- Изберете роля --";

    private string firstName = string.Empty;
    private string lastName = string.Empty;
    private string Password = string.Empty;
    private string ConfirmPassword = string.Empty;

    private UsersService _usersService;
    private LogsService _logsService;
    private User currentUser = new();
    private List<User> users = new();
    private List<User> allUsers = new();

    private bool IsPasswordVisible = false;
    private bool IsConfirmPasswordVisible = false;

    private string PasswordInputType => IsPasswordVisible ? "text" : "password";
    private string ConfirmPasswordInputType => IsConfirmPasswordVisible ? "text" : "password";

    private string searchStr;
    private string SearchStr
    {
        get => searchStr;
        set { searchStr = value; FilterUsers(); }
    }

    private bool IsMale() => currentUser.Gender == 'm';
    private bool IsFemale() => currentUser.Gender == 'f';

    protected override async Task OnInitializedAsync()
    {
        if (Session?.CurrentUser == null || Session.CurrentUser.RoleId != 2)
        {
            Nav.NavigateTo("/");
            return;
        }
        _usersService = new UsersService(DbContext);
        _logsService = new LogsService(DbContext);
        allUsers = users = await _usersService.GetAllUsers();
    }

    void OpenEdit(User user)
    {
        currentUser = user;
        var names = user.Name.Split(' ', 2);
        firstName = names[0];
        lastName = names.Length > 1 ? names[1] : "";
        Password = string.Empty;
        ConfirmPassword = string.Empty;
        selectedRoleLabel = user.RoleId switch { 1 => "Потребител", 2 => "Администратор", _ => "-- Изберете роля --" };
        isAdding = false;
        submitAttempted = false;
        isEditOpen = true;
    }

    void OpenAddUser()
    {
        currentUser = new();
        firstName = lastName = Password = ConfirmPassword = string.Empty;
        selectedRoleLabel = "-- Изберете роля --";
        isAdding = true;
        submitAttempted = false;
        isEditOpen = true;
    }

    void CloseEdit()
    {
        isEditOpen = false;
        submitAttempted = false;
    }

    async Task SaveUser()
    {
        submitAttempted = true;

        bool valid = isAdding ? VerifyAddUser() : VerifyEditUser();
        if (!valid) return;

        currentUser.Name = $"{firstName.Trim()} {lastName.Trim()}";

        if (isAdding)
        {
            currentUser.Password = Password;
            currentUser.UserCode = GenerateUniqueUserCode();
            await _usersService.CreateUser(currentUser);
            allUsers.Add(currentUser);
        }
        else
        {
            await _usersService.UpdateUser(currentUser);
            // Only update password if the user typed one
            if (!string.IsNullOrEmpty(Password))
                await _usersService.UpdatePassword(currentUser);
        }

        users = new List<User>(allUsers);
        isEditOpen = false;
        submitAttempted = false;
    }

    void OpenDelete(User user)
    {
        currentUser = user;
        isDeleteOpen = true;
    }

    void CloseDelete() => isDeleteOpen = false;

    async Task ConfirmDelete()
    {
        isDeleteOpen = false;
        users.Remove(currentUser);
        allUsers.Remove(currentUser);
        await _logsService.CreateLog(currentUser, "Успешно изтрит от Админ");
        await _usersService.DeleteUser(currentUser);
    }

    void ToggleDropdown() => isDropdownOpen = !isDropdownOpen;
    void CloseDropdown() => isDropdownOpen = false;

    void SelectRole(int roleId)
    {
        currentUser.RoleId = roleId;
        selectedRoleLabel = roleId switch { 1 => "Потребител", 2 => "Администратор", _ => "-- Изберете роля --" };
        isDropdownOpen = false;
    }

    void TogglePasswordVisibility() => IsPasswordVisible = !IsPasswordVisible;
    void ToggleConfirmPasswordVisibility() => IsConfirmPasswordVisible = !IsConfirmPasswordVisible;
    void SelectGender(char gender) => currentUser.Gender = gender;

    // ── Validation ──

    /// <summary>All fields required when adding.</summary>
    private bool VerifyAddUser() =>
        VerifyFirstName() && VerifyLastName() && VerifyGender() &&
        VerifyUsername() && VerifyRole() &&
        VerifyPassword() && VerifyConfirmPassword();

    /// <summary>
    /// When editing: name, gender, username and role are always required.
    /// Password fields are only validated when the user has started typing a new password.
    /// </summary>
    private bool VerifyEditUser() =>
        VerifyFirstName() && VerifyLastName() && VerifyGender() &&
        VerifyUsername() && VerifyRole() &&
        VerifyPassword() && VerifyConfirmPassword();

    private bool VerifyFirstName() => !string.IsNullOrWhiteSpace(firstName) && firstName.Trim().Length >= 2;
    private bool VerifyLastName() => !string.IsNullOrWhiteSpace(lastName) && lastName.Trim().Length >= 2;
    private bool VerifyGender() => currentUser.Gender == 'm' || currentUser.Gender == 'f';
    private bool VerifyRole() => currentUser.RoleId > 0;

    private bool VerifyUsername() =>
        !string.IsNullOrWhiteSpace(currentUser.Username) &&
        !users.Any(u => u.Username == currentUser.Username && u != currentUser);

    private bool VerifyPassword()
    {
        // Adding: password is required and must meet complexity rules
        if (isAdding)
        {
            var pw = Password?.Trim() ?? "";
            return pw.Length >= 12
                && pw.Any(char.IsUpper)
                && pw.Any(char.IsLower)
                && pw.Any(char.IsDigit)
                && pw.Any(c => !char.IsLetterOrDigit(c));
        }
        // Editing: password field is empty → skip validation (not changing password)
        if (string.IsNullOrEmpty(Password)) return true;
        // Editing: user typed something → enforce complexity
        var p = Password.Trim();
        return p.Length >= 12
            && p.Any(char.IsUpper)
            && p.Any(char.IsLower)
            && p.Any(char.IsDigit)
            && p.Any(c => !char.IsLetterOrDigit(c));
    }

    private bool VerifyConfirmPassword()
    {
        // Adding: always required to match
        if (isAdding)
            return (Password?.Trim() ?? "") == (ConfirmPassword?.Trim() ?? "");
        // Editing: only validate if password field has a value
        if (string.IsNullOrEmpty(Password)) return true;
        return (Password?.Trim() ?? "") == (ConfirmPassword?.Trim() ?? "");
    }

    private void FilterUsers()
    {
        if (string.IsNullOrWhiteSpace(searchStr))
        {
            users = new List<User>(allUsers);
            return;
        }
        users = allUsers
            .Where(u =>
                u.Name.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
                u.Username.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
                (u.RoleId == 1 && "Потребител".Contains(searchStr, StringComparison.OrdinalIgnoreCase)) ||
                (u.RoleId == 2 && "Администратор".Contains(searchStr, StringComparison.OrdinalIgnoreCase)))
            .ToList();
    }

    private static string GenerateCode()
    {
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        var random = new Random();
        return new string(Enumerable.Repeat(chars, 6).Select(s => s[random.Next(s.Length)]).ToArray());
    }

    private string GenerateUniqueUserCode()
    {
        string code;
        do { code = GenerateCode(); } while (_usersService.IsCodeExisting(code));
        return code;
    }
}
<script>
    window.goBack = () => {
        history.back();
    }
</script>