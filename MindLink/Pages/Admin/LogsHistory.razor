@page "/admin/user-logs"
@using MindLink.Data.Models
@using MindLink.Data.Services
@inject MindLink.Data.MindLinkDbContext DbContext
<link href="css/Homepage.css" rel="stylesheet" />
<link href="css/admin.css" rel="stylesheet" />

<PageTitle>MindLink - История на влизанията</PageTitle>

<h1 class="page-title" style="margin-bottom: 35px;">Проследяване на дейността</h1>

<div class="users-header">
    <input type="text" placeholder="Търси потребител..." class="search-input" 
           @bind="SearchStr" @bind:event="oninput" />
</div>

<table class="users-table">
    <thead>
        <tr>
            <th>Дата и час</th>
            <th>Потребител</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @if (logs.Any())
        {
            @foreach (var entry in logs.OrderByDescending(x => x.Date))
            {
                <tr>
                    <td>@entry.Date.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@entry.User.Username</td>
                    <td>
                        <span class="@(entry.Status.Contains("У") ? "status-success" : "status-fail")">
                            @entry.Status
                        </span>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" style="text-align:center;">Няма записи</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private LogsService _logsService;
    private List<Log> logs = new();
    private List<Log> allLogs = new();
    private string searchStr;

    private string SearchStr
    {
        get => searchStr;
        set
        {
            searchStr = value;
            FilterLogs();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _logsService = new LogsService(DbContext);
        allLogs = logs = await _logsService.GetAllLogs();
    }

    private void FilterLogs()
    {
        if (string.IsNullOrWhiteSpace(searchStr))
        {
            logs = new List<Log>(allLogs);
        }
        else
        {
            logs = allLogs
                .Where(x => x.User.Username.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
                            x.Status.Contains(searchStr, StringComparison.OrdinalIgnoreCase) || (x.User.Role?.Name?.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }
    }
}
