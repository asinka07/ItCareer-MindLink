@page "/users-logs"
@using MindLink.Data.Models
@using MindLink.Data.Services
@inject MindLink.Data.MindLinkDbContext DbContext
<link href="css/Homepage.css" rel="stylesheet" />
<link href="css/admin.css" rel="stylesheet" />

<PageTitle>MindLink - История на влизанията</PageTitle>

<div class="users-header">
    <input type="text" placeholder="Търси потребител..." class="search-input" @bind="searchStr" @bind:event="oninput" />
</div>

<table class="users-table">
    <thead>
        <tr>
            <th>Дата и час</th>
            <th>Потребител</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var entry in logs.OrderByDescending(x => x.Date))
        {
            <tr>
                <td>@entry.Date.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@entry.User.Username</td>
                <td>
                    <span class="@(entry.Status.Contains("У") ? "status-success" : "status-fail")">
                        @entry.Status
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
	private bool submitAttempted = false;

	string firstName = string.Empty;
	string lastName = string.Empty;

	LogsService _logsService = null;
	List<Log> logs = new List<Log>();

	private string searchStr;

	private string SearchStr
	{
		get => searchStr;
		set
		{
			searchStr = value;
			_ = Search();
		}
	}

	protected override async void OnInitialized()
	{
		base.OnInitialized();
		_logsService = new LogsService(DbContext);
		logs = await _logsService.GetAllLogs();
		StateHasChanged();
	}
	async Task Search()
	{
		if (!string.IsNullOrEmpty(searchStr))
		{
			logs = logs.Where(x => x.User.Username.Contains(searchStr, StringComparison.OrdinalIgnoreCase) ||
				x.Status.Contains(searchStr, StringComparison.OrdinalIgnoreCase)).ToList();
		}
		else
		{
			logs = await _logsService.GetAllLogs();
		}
		StateHasChanged();
	}
}

