@page "/login"
@inject UserSessionService Session
@inject NavigationManager Nav
@inject MindLink.Data.MindLinkDbContext DbContext
@using MindLink.Data.Models
@using Microsoft.AspNetCore.Identity
@using MindLink.Data.Services

<link href="css/mindlink-register.css" rel="stylesheet" />

<PageTitle>Вход в ML</PageTitle>

<div class="registration-page">
    <div class="registration-form">

        <div class="header">
            <div class="logo">ML</div>
            <h2>Вход в MindLink</h2>
            <p class="muted">Добре дошъл обратно </p>
        </div>

        <div class="auth-container">

            <div class="field">
                <label>Потребителско име</label>
                <input type="text" @bind="Username" placeholder="user_example" />
            </div>

            <div class="field">
                <label>Парола</label>
                <div class="password-wrapper">
                    <input type="@PasswordInputType" @bind="Password" placeholder="••••••••••" />
                    <button type="button" class="eye-btn" @onclick="TogglePasswordVisibility">
                        @(IsPasswordVisible ? "🙈" : "👁️")
                    </button>
                </div>
            </div>

            @if (submitAttempted && !isLoading && !ValidUser())
            {
                <div class="text-danger" style="text-align: center">
                    Невалидно потребителско име или парола.
                </div>
            }

            <button class="btn primary" @onclick="Log" disabled="@isLoading">
                @(isLoading ? "Зареждане..." : "Вход")
            </button>

            <p class="muted small">
                Нямаш акаунт? <a href="/signup">Регистрирай се</a>
            </p>

        </div>
    </div>
</div>

@code {
    User? user = null;
    private bool isLoading = false;
    private bool submitAttempted = false;

    private string username = string.Empty;
    private string Username
    {
        get => username;
        set
        {
            username = value;
            user = null;
        }
    }

    private string Password { get; set; } = string.Empty;

    private bool IsPasswordVisible = false;
    private string PasswordInputType => IsPasswordVisible ? "text" : "password";
    private void TogglePasswordVisibility() => IsPasswordVisible = !IsPasswordVisible;

    protected override void OnInitialized()
    {
        Session.LogOut();
    }

    private async Task Log()
    {
        submitAttempted = true;
        isLoading = true;

        if (string.IsNullOrWhiteSpace(Username))
        {
            isLoading = false;
            return;
        }

        var usersService = new UsersService(DbContext);
        var logsService = new LogsService(DbContext);

        user = await usersService.GetUserByUsername(Username);
        isLoading = false;

        if (ValidUser() && user!.RoleId == 1)
        {
            await Session.LogIn(user);
            user.LastLogin = DateTime.Now;
            await usersService.LogUser(user);
            await logsService.CreateLog(user, "Успешен вход");
            Nav.NavigateTo("/homepage");
        }
        else if (ValidUser() && user!.RoleId == 2)
        {
            await Session.LogIn(user);
            user.LastLogin = DateTime.Now;
            await usersService.LogUser(user);
            await logsService.CreateLog(user, "Успешен вход");
            Nav.NavigateTo("/admin/dashboard");
        }
        else
        {
            var systemUser = await usersService.GetUserByCode("111111");
            if (systemUser != null)
                await logsService.CreateLog(systemUser, "Неуспешен вход");

            StateHasChanged();
        }
    }

    private bool ValidUser()
    {
        if (user == null || string.IsNullOrWhiteSpace(Password))
            return false;

        var hasher = new PasswordHasher<User>();
        var result = hasher.VerifyHashedPassword(user, user.Password, Password);
        return result == PasswordVerificationResult.Success;
    }
}